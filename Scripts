        TweenService:Create(tog, TweenInfo.new(0.2), {
            BackgroundColor3 = s and Color3.fromRGB(100,70,210) or Color3.fromRGB(45,35,75)
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.2), {
