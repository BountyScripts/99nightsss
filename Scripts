-- ЛОГИКА RunService — ИСПРАВЛЕННАЯ
-- ================================================
local farmCD, chopCD, collectCD = 0, 0, 0

RunService.Heartbeat:Connect(function(dt)
    if not Char or not Hum or not Root then return end
    farmCD -= dt; chopCD -= dt; collectCD -= dt

    -- АВТОФАРМ Shadow Cultist
    if Config.AutoFarm and farmCD <= 0 then
        farmCD = 0.25
        local nearest, dist = nil, 60
        for _, obj in pairs(workspace:GetDescendants()) do
            -- ФИКС: ищем по имени модели, не через Position напрямую
            if obj:IsA("Model")
            and (obj.Name == "Shadow Cultist" or obj.Name:find("Cultist") or obj.Name:find("Shadow"))
            and obj ~= Char then
                local hum = obj:FindFirstChildWhichIsA("Humanoid")
                if hum and hum.Health > 0 then
                    local pos = GetPos(obj) -- ФИКС: безопасное получение позиции
                    if pos then
                        local d = (Root.Position - pos).Magnitude
                        if d < dist then dist = d; nearest = obj end
                    end
                end
            end
        end
        if nearest then
            local cf = GetCF(nearest)
            if cf then
                -- Встаём рядом с мобом
                Root.CFrame = cf + Vector3.new(0, 2, 2.5)
                -- Активируем инструмент
                local tool = Char:FindFirstChildWhichIsA("Tool")
                if tool then
                    pcall(function() tool:Activate() end)
                    for _, v in pairs(tool:GetDescendants()) do
                        if v:IsA("RemoteEvent") then
                            pcall(function() v:FireServer(nearest) end)
                        end
                    end
                end
            end
        end
    end

    -- АВТОРУБКА деревьев
    if Config.AutoChop and chopCD <= 0 then
        chopCD = 0.3
        local nearestTree, treeDist = nil, 80
        for _, obj in pairs(workspace:GetDescendants()) do
            local name = obj.Name:lower()
            for _, tname in pairs(Config.TreeNames) do
                if name:find(tname:lower()) then
                    local pos = GetPos(obj)
                    if pos then
                        local d = (Root.Position - pos).Magnitude
                        if d < treeDist and not obj:IsDescendantOf(Char) then
                            treeDist = d; nearestTree = obj
                        end
                    end
                    break
                end
            end
        end
        if nearestTree then
            local cf = GetCF(nearestTree)
            if cf then
                Root.CFrame = cf + Vector3.new(0,1,2.5)
                local tool = Char:FindFirstChildWhichIsA("Tool")
                if tool then
                    pcall(function() tool:Activate() end)
                    for _, v in pairs(tool:GetDescendants()) do
                        if v:IsA("RemoteEvent") then
                            pcall(function() v:FireServer(nearestTree) end)
                        end
                    end
                end
            end
        end
    end

    -- АВТОСБОР
    if Config.AutoCollect and collectCD <= 0 then
        collectCD = 0.2
        local nearest, dist = nil, 80
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj.Anchored
            and not obj:IsDescendantOf(Char)
            and obj.Size.Magnitude < 8
            and obj.Parent ~= workspace then
                local d = (Root.Position - obj.Position).Magnitude
                if d < dist and d > 1 then dist = d; nearest = obj end
            end
        end
        if nearest then
            Root.CFrame = CFrame.new(nearest.Position + Vector3.new(0,2,0))
        end
    end

    -- НЕТ-КЛИП
    if Config.NoClip then
        for _, p in pairs(Char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end
end)

