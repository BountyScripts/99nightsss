    {"🧪","Potion"}, {"⚗️","Herb"}, {"🪙","Coin"},
    {"💰","Gold"}, {"📦","Chest"}, {"🗝️","Key"},
}

local function BuildItemList(filter)
    for _, c in pairs(ItemList:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    for _, item in pairs(ITEMS) do
        local emoji, name = item[1], item[2]
        if filter == "" or name:lower():find(filter:lower()) then
            local btn = Instance.new("TextButton", ItemList)
            btn.Text = emoji .. "  " .. name
            btn.Size = UDim2.new(1,0,0,32)
            btn.BackgroundColor3 = Color3.fromRGB(22,18,45)
            btn.Font = Enum.Font.GothamSemibold
            btn.TextSize = 12
            btn.TextColor3 = Color3.fromRGB(200,185,240)
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.BorderSizePixel = 0
            btn.ZIndex = 10
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
            local BP = Instance.new("UIPadding", btn)
            BP.PaddingLeft = UDim.new(0,10)

            btn.MouseButton1Click:Connect(function()
                for _, c2 in pairs(ItemList:GetChildren()) do
                    if c2:IsA("TextButton") then
                        c2.BackgroundColor3 = Color3.fromRGB(22,18,45)
                        c2.TextColor3 = Color3.fromRGB(200,185,240)
                    end
                end
                btn.BackgroundColor3 = Color3.fromRGB(80,55,170)
                btn.TextColor3 = Color3.fromRGB(255,240,255)

                local count = 0
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj.Name == name or obj.Name:lower():find(name:lower()) then
                        local pos = GetPos(obj)
                        if pos and not obj:IsDescendantOf(Char) then
                            pcall(function()
                                if obj:IsA("BasePart") then
                                    obj.CFrame = Root.CFrame + Vector3.new(math.random(-2,2),1,math.random(-2,2))
                                elseif obj:IsA("Model") and obj.PrimaryPart then
                                    obj:SetPrimaryPartCFrame(Root.CFrame + Vector3.new(math.random(-2,2),1,math.random(-2,2)))
                                end
                            end)
                            count = count + 1
                        end
                    end
                end
                IWTitle.Text = "✅ " .. count .. " шт. притянуто!"
                task.delay(2, function() IWTitle.Text = "📦 Выбери предмет" end)
            end)
        end
    end
end

