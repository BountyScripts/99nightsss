-- Безопасное получение позиции любого объекта
local function GetPos(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj.Position end
    if obj:IsA("Model") then
        -- Сначала ищем HumanoidRootPart
        local hrp = obj:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp.Position end
        -- Потом PrimaryPart
        if obj.PrimaryPart then return obj.PrimaryPart.Position end
        -- Потом любой BasePart
        local bp = obj:FindFirstChildWhichIsA("BasePart")
        if bp then return bp.Position end
    end
    return nil
end

-- Безопасное получение CFrame
local function GetCF(obj)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj.CFrame end
    if obj:IsA("Model") then
        local hrp = obj:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp.CFrame end
        if obj.PrimaryPart then return obj.PrimaryPart.CFrame end
        local bp = obj:FindFirstChildWhichIsA("BasePart")
        if bp then return bp.CFrame end
    end
    return nil
end

