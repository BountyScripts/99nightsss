            Position = s and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
        }):Play()
    end
    Upd(Config[key])
    tog.MouseButton1Click:Connect(function()
        Config[key] = not Config[key]
        Upd(Config[key])
